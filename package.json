{
  "name": "devtoolbox",
  "version": "2.0.2",
  "description": "Cross-platform desktop toolbox",
  "author": "Jacobs",
  "license": "Apache-2.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "packageManager": "pnpm@10.10.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "node scripts/exec-without-node-options.mjs vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "new:tool": "node scripts/new-tool.mjs",
    "lint:modules": "node scripts/lint-modules.mjs && node scripts/lint-marketplace.mjs",
    "lint": "pnpm lint:modules && eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "pnpm rebuild -r electron esbuild",
    "package:mac": "pnpm run build && electron-builder --mac --publish never",
    "package:win": "pnpm run build && electron-builder --win --publish never",
    "package:all": "pnpm run build && electron-builder --mac --win --publish never"
  },
  "dependencies": {
    "@codemirror/commands": "6.10.3",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/search": "6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@devtoolbox/core": "workspace:*",
    "@devtoolbox/ui": "workspace:*",
    "bwip-js": "^4.8.0",
    "codemirror": "^6.0.2",
    "diff": "^8.0.3",
    "events": "^3.3.0",
    "electron-updater": "^6.6.2",
    "extract-zip": "^2.0.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.0",
    "fast-xml-parser": "^4.5.3",
    "javascript-obfuscator": "^5.3.0",
    "marked": "^17.0.4",
    "mqtt": "^5.15.0",
    "lucide-react": "^0.469.0",
    "pinyin-pro": "^3.28.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react18-json-view": "^0.2.9",
    "terser": "^5.46.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@types/bwip-js": "^3.2.3",
    "@types/diff": "^7.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.19.39",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fast-check": "^3.23.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.5",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^2.1.8"
  }
}
